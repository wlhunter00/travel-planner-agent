# ── Database (Vercel Postgres / Neon) ─────────────────────────────────────
# Provision Vercel Postgres in the dashboard, then pull locally:
#   vercel env pull .env.local
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── Auth.js ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-32-byte-secret

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Comma-separated list of emails allowed to sign in. Leave empty to allow anyone.
ALLOWED_EMAILS=you@gmail.com,friend@gmail.com

# Required for OAuth callbacks. In production, set to your deployed URL.
# In Vercel preview/production deployments, AUTH_URL is auto-detected.
AUTH_URL=http://localhost:3000

# ── Existing keys (unchanged) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

EXA_API_KEY=your-exa-api-key
SERPAPI_API_KEY=your-serpapi-api-key

# No key needed — connects automatically
# PEEK_MCP_ENDPOINT=https://mcp.peek.com

# Phase 2: Wanderlog browser automation (optional)
# WANDERLOG_ENABLED=true
